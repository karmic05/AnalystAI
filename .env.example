# ─────────────────────────────────────────────────────────────
# AnalystAI environment variables
# Copy to .env.local and fill in. The app runs fully offline with
# these unset — the LocalAnalyst provider is the default.
# ─────────────────────────────────────────────────────────────

# Default AI provider: "local" (offline, deterministic) or "llm".
ANALYSTAI_AI_PROVIDER=local

# Only required when ANALYSTAI_AI_PROVIDER=llm.
# The orchestrator routes tasks to models; any OpenAI-compatible
# chat-completions endpoint works (OpenAI, Vercel AI Gateway, etc.).
ANALYSTAI_LLM_BASE_URL=https://api.openai.com/v1
ANALYSTAI_LLM_API_KEY=
ANALYSTAI_LLM_MODEL_REASONING=gpt-4o-mini
ANALYSTAI_LLM_MODEL_SQL=gpt-4o-mini
ANALYSTAI_LLM_MODEL_REPORT=gpt-4o

# Optional: Stripe (billing is simulated in the prototype).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: Vercel deployment region
VERCEL_REGION=
