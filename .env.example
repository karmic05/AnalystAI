# ─────────────────────────────────────────────────────────────
# AnalystAI environment variables
# Copy to .env.local and fill in. The app runs fully offline with
# these unset — the LocalAnalyst provider is the default.
# ─────────────────────────────────────────────────────────────

# ── AI provider ───────────────────────────────────────────────
# The app runs fully offline by default (deterministic local engine).
# Set a Groq key to upgrade chat, reports and interpretations to
# LLM-authored prose. Groq's free tier is the default provider.
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# The engine still computes every number; the LLM only writes prose
# grounded in that context, so figures can't be hallucinated. On any
# LLM error the orchestrator falls back to the local engine.
#
# Any OpenAI-compatible chat-completions endpoint works. Defaults to
# Groq; override the base URL to use OpenAI, the Vercel AI Gateway, etc.
ANALYSTAI_LLM_BASE_URL=https://api.groq.com/openai/v1
# Legacy fallback key (used only if GROQ_API_KEY is unset).
ANALYSTAI_LLM_API_KEY=
ANALYSTAI_LLM_MODEL_REASONING=llama-3.3-70b-versatile
ANALYSTAI_LLM_MODEL_SQL=llama-3.1-8b-instant
ANALYSTAI_LLM_MODEL_REPORT=llama-3.3-70b-versatile

# Optional: Stripe (billing is simulated in the prototype).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: Vercel deployment region
VERCEL_REGION=
